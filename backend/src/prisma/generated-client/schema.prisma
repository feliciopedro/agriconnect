datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

enum Role {
  FARMER
  BUYER
  TRANSPORT
  ADMIN
  SUPERADMIN
}

enum CropType {
  TOMATO
  PEPPER
  GARDEN_EGG
  OKRA
  LEAFY_GREENS
  OTHER
}

enum ListingStatus {
  AVAILABLE
  RESERVED
  SOLD_OUT
  EXPIRED
}

enum QualityGrade {
  A
  B
  C
  UNGRADED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum DeliveryStatus {
  REQUESTED
  MATCHED
  PICKED_UP
  DELIVERED
}

enum BusinessType {
  RETAILER
  RESTAURANT
  PROCESSOR
  EXPORTER
  HOUSEHOLD
}

enum TraceEventType {
  HARVESTED
  LISTED
  QUALITY_CHECKED
  RESERVED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
}

enum CreationSource {
  WEB
  USSD
  SMS
}

// User: unified table for all system users
model User {
  id                String    @id @default(uuid())
  phone             String    @unique
  name              String
  role              Role
  latitude          Float?
  longitude         Float?
  region            String?
  district          String?
  isVerified        Boolean   @default(false)
  passwordHash      String?
  preferredLanguage String    @default("en")
  ussdPin           String?
  ussdPinSetAt      DateTime?
  lastUssdActivity  DateTime?
  lockoutUntil      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // 1:1 Profiles
  farmerProfile    FarmerProfile?
  buyerProfile     BuyerProfile?
  transportProfile TransportProfile?

  // Relations
  listings            ProduceListing[]
  orders              Order[]           @relation("BuyerOrders")
  deliveries          DeliveryRequest[] @relation("TransporterDeliveries")
  sentReviews         Review[]          @relation("SentReviews")
  receivedReviews     Review[]          @relation("ReceivedReviews")
  notifications       Notification[]
  sentMessages        Message[]         @relation("SentMessages")
  receivedMessages    Message[]         @relation("ReceivedMessages")
  recordedTraceEvents TraceEvent[]      @relation("RecordedEvents")
  preOrders           PreOrder[]        @relation("BuyerPreOrders")
  plantingLogs        PlantingLog[]     @relation("FarmerPlantingLogs")
  auditLogs           AuditLog[]        @relation("UserAuditLogs")
  configsUpdated      SystemConfig[]    @relation("ConfigUpdater")
  ban                 UserBan?          @relation("BannedUser")
  bansIssued          UserBan[]         @relation("UserBanner")
  ussdSessions        UssdSession[]

  @@index([role])
  @@index([latitude, longitude])
}

// Profile linked to Farmers
model FarmerProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  farmSizeAcres Float?
  primaryCrops  String[]
  avgRating     Float    @default(0)
  totalReviews  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Profile linked to Buyers
model BuyerProfile {
  id           String       @id @default(uuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessType BusinessType
  avgRating    Float        @default(0)
  totalReviews Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// Profile linked to Transporters
model TransportProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleType     String
  capacityKg      Float
  serviceRadiusKm Float    @default(15)
  isAvailable     Boolean  @default(true)
  avgRating       Float    @default(0)
  totalReviews    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ProduceListing: listings created by Farmers
model ProduceListing {
  id                 String              @id @default(uuid())
  farmerId           String
  farmer             User                @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  cropType           CropType
  quantityKg         Float
  remainingKg        Float
  pricePerKg         Float
  images             String[]
  harvestDate        DateTime
  expiryEstimate     DateTime?
  qualityGrade       QualityGrade        @default(UNGRADED)
  qualityGradeSource String              @default("UNGRADED") // "AI" or "MANUAL"
  status             ListingStatus       @default(AVAILABLE)
  latitude           Float
  longitude          Float
  batchCode          String              @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  source             CreationSource      @default(WEB)
  orders             Order[]
  traceability       TraceabilityRecord?
  traceEvents        TraceEvent[]
  preOrders          PreOrder[]          @relation("PreOrderListing")
  plantingLogId      String?
  plantingLog        PlantingLog?        @relation(fields: [plantingLogId], references: [id], onDelete: SetNull)

  @@index([cropType, status])
  @@index([latitude, longitude])
  @@index([farmerId])
  @@index([status])
  @@index([plantingLogId])
}

// TraceabilityRecord: 1:1 details for quality audits
model TraceabilityRecord {
  id                 String         @id @default(uuid())
  listingId          String         @unique
  listing            ProduceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  plantingDate       DateTime?
  inputsUsed         String[]
  qualityCheckImages String[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

// TraceEvent: append-only ledger for listing logs
model TraceEvent {
  id               String         @id @default(uuid())
  listingId        String
  listing          ProduceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  eventType        TraceEventType
  latitude         Float?
  longitude        Float?
  recordedByUserId String?
  recordedByUser   User?          @relation("RecordedEvents", fields: [recordedByUserId], references: [id], onDelete: SetNull)
  notes            String?
  timestamp        DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([listingId])
  @@index([timestamp])
}

// Order: purchase transactions
model Order {
  id                String           @id @default(uuid())
  buyerId           String
  buyer             User             @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  listingId         String
  listing           ProduceListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  quantityKg        Float
  totalPrice        Float
  status            OrderStatus      @default(PENDING)
  paymentStatus     PaymentStatus    @default(UNPAID)
  paystackReference String?
  depositCredit     Float            @default(0) // amount credited from a pre-order deposit
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  source            CreationSource   @default(WEB)
  deliveryRequest   DeliveryRequest?
  reviews           Review[]
  messages          Message[]
  preOrder          PreOrder?        @relation("PreOrderOrder")

  @@index([buyerId])
  @@index([listingId])
  @@index([status])
}

// DeliveryRequest: transporter matchings
model DeliveryRequest {
  id                  String         @id @default(uuid())
  orderId             String         @unique
  order               Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transportProviderId String?
  transportProvider   User?          @relation("TransporterDeliveries", fields: [transportProviderId], references: [id], onDelete: SetNull)
  pickupLatitude      Float
  pickupLongitude     Float
  dropoffLatitude     Float
  dropoffLongitude    Float
  scheduledPickup     DateTime?
  scheduledDropoff    DateTime?
  estimatedCost       Float?
  status              DeliveryStatus @default(REQUESTED)
  routeGroupId        String?
  routeSequence       Json?
  eta                 DateTime?
  currentLatitude     Float?
  currentLongitude    Float?
  routeDistanceKm     Float?
  routeDurationMin    Float?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([status])
  @@index([routeGroupId])
  @@index([transportProviderId])
  @@index([pickupLatitude, pickupLongitude])
  @@index([dropoffLatitude, dropoffLongitude])
}

// Review: feedback between platform users
model Review {
  id         String   @id @default(uuid())
  fromUserId String
  fromUser   User     @relation("SentReviews", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User     @relation("ReceivedReviews", fields: [toUserId], references: [id], onDelete: Cascade)
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([fromUserId, orderId])
  @@index([toUserId])
  @@index([fromUserId])
  @@index([orderId])
}

// Notification: direct operational logs
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isRead])
}

// Message: unified text chats
model Message {
  id         String   @id @default(uuid())
  fromUserId String
  fromUser   User     @relation("SentMessages", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User     @relation("ReceivedMessages", fields: [toUserId], references: [id], onDelete: Cascade)
  orderId    String?
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([fromUserId, toUserId])
  @@index([orderId])
}

// OtpCode: validation pins
model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone, isUsed])
}

// UssdSession: interactive session state machine
model UssdSession {
  id             String    @id @default(uuid())
  sessionId      String    @unique
  phone          String
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language       String    @default("en")
  currentMenu    String
  currentStep    String
  menuStack      Json      @default("[]")
  tempData       Json      @default("{}")
  inputHistory   Json      @default("[]")
  startedAt      DateTime  @default(now())
  lastActivityAt DateTime  @updatedAt
  isActive       Boolean   @default(true)
  endedAt        DateTime?
  endReason      String?

  @@index([phone, isActive])
  @@index([sessionId])
}

model UssdAuditLog {
  id             String   @id @default(uuid())
  sessionId      String
  phone          String
  userId         String?
  menu           String
  step           String
  userInput      String?
  systemResponse String
  action         String?
  metadata       Json?
  timestamp      DateTime @default(now())

  @@index([phone, timestamp])
  @@index([action])
}

model UssdShortMessage {
  id            String            @id @default(uuid())
  toPhone       String
  message       String
  triggerAction String
  status        UssdMessageStatus
  attemptCount  Int               @default(0)
  sentAt        DateTime?
  errorMessage  String?
  createdAt     DateTime          @default(now())

  @@index([status, createdAt])
}

enum UssdMessageStatus {
  QUEUED
  SENT
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// PRE-ORDERS & DEMAND FORECASTING
// ─────────────────────────────────────────────────────────────────────────────

enum PreOrderStatus {
  DEPOSIT_PENDING // created, awaiting deposit payment via Paystack
  OPEN // deposit paid, actively seeking a matching listing
  MATCHED // linked to a farmer listing, awaiting full order placement
  FULFILLED // converted to a real Order with deposit credit applied
  CANCELLED // buyer cancelled before fulfillment
  EXPIRED // harvest window passed with no matching listing found
}

// PreOrder: demand-side intent before a listing exists
model PreOrder {
  id                 String          @id @default(uuid())
  buyerId            String
  buyer              User            @relation("BuyerPreOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  cropType           CropType
  quantityKg         Float
  maxPricePerKg      Float // buyer's ceiling — matching only happens if listing.pricePerKg <= this
  preferredRegion    String? // null = any region in Ghana
  harvestWindowStart DateTime // earliest acceptable harvest date
  harvestWindowEnd   DateTime // latest acceptable harvest date; also used as expiry
  notes              String?
  depositAmount      Float // computed: quantityKg * maxPricePerKg * DEPOSIT_PCT (default 20%)
  depositPaid        Boolean         @default(false)
  paystackReference  String? // "PRE-{id}-{timestamp}" stored for webhook lookup
  status             PreOrderStatus  @default(DEPOSIT_PENDING)
  matchedListingId   String? // set when status becomes MATCHED
  matchedListing     ProduceListing? @relation("PreOrderListing", fields: [matchedListingId], references: [id], onDelete: SetNull)
  fulfilledOrderId   String?         @unique // set when status becomes FULFILLED
  fulfilledOrder     Order?          @relation("PreOrderOrder", fields: [fulfilledOrderId], references: [id], onDelete: SetNull)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([buyerId])
  @@index([cropType, status])
  @@index([status])
  @@index([harvestWindowEnd])
}

// ─────────────────────────────────────────────────────────────────────────────
// FARM & CROP MANAGEMENT (PLANTING JOURNAL)
// ─────────────────────────────────────────────────────────────────────────────

model PlantingLog {
  id                  String           @id @default(uuid())
  farmerId            String
  farmer              User             @relation("FarmerPlantingLogs", fields: [farmerId], references: [id], onDelete: Cascade)
  cropType            CropType
  acreage             Float
  plantingDate        DateTime
  expectedHarvestDate DateTime
  actualHarvestDate   DateTime?
  actualYieldKg       Float? // yield achieved on harvest completion
  notes               String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  inputs              PlantingInput[]
  listings            ProduceListing[]

  @@index([farmerId])
  @@index([cropType])
}

model PlantingInput {
  id            String      @id @default(uuid())
  plantingLogId String
  plantingLog   PlantingLog @relation(fields: [plantingLogId], references: [id], onDelete: Cascade)
  type          String // "FERTILIZER" | "PESTICIDE" | "IRRIGATION" | "OTHER"
  name          String // e.g. "NPK 15-15-15", "Drip irrigation"
  quantity      Float?
  unit          String? // e.g. "kg", "bags", "liters", "hours"
  appliedAt     DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([plantingLogId])
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPLIANCE & DISPUTE RESOLUTION (IMMUTABLE AUDIT LOGGING)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actor      User     @relation("UserAuditLogs", fields: [actorId], references: [id], onDelete: Cascade)
  actorRole  Role
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([timestamp])
}

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedBy   String
  updater     User     @relation("ConfigUpdater", fields: [updatedBy], references: [id])
  updatedAt   DateTime @updatedAt
}

model UserBan {
  id        String    @id @default(uuid())
  userId    String    @unique
  user      User      @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  bannedBy  String
  banner    User      @relation("UserBanner", fields: [bannedBy], references: [id])
  reason    String
  bannedAt  DateTime  @default(now())
  expiresAt DateTime?
  isActive  Boolean   @default(true)
}
