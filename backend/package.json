{
  "name": "agriconnect-backend",
  "version": "1.0.0",
  "description": "AgriConnect backend API server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "postinstall": "prisma generate --schema src/prisma/schema.prisma",
    "build": "prisma generate --schema src/prisma/schema.prisma && tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --schema src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "seed": "ts-node src/prisma/seed.ts",
    "db:seed": "ts-node src/prisma/seed.ts",
    "test": "jest --testTimeout=30000 --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "test:ussd": "ts-node --transpile-only src/scripts/test-ussd.ts",
    "test:ussd:twi": "ts-node --transpile-only src/scripts/test-ussd.ts --lang=tw --role=FARMER",
    "test:ussd:ewe": "ts-node --transpile-only src/scripts/test-ussd.ts --lang=ew --role=BUYER",
    "test:ussd:hausa": "ts-node --transpile-only src/scripts/test-ussd.ts --lang=ha --role=TRANSPORT"
  },
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "africastalking": "^0.6.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "paystack-node": "^0.3.0",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.9",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "prisma": "^5.16.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
