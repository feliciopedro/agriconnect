# Server Ports and Host Configuration
PORT=5000
NODE_ENV=development

# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/agriconnect?schema=public"

# Authentication
JWT_SECRET="replace_with_a_long_secure_random_string"

# Frontend URL (Used for CORS origin configuration)
FRONTEND_URL="http://localhost:5173"

# Africa's Talking Gateway (SMS Services)
AFRICAS_TALKING_USERNAME="sandbox"
AFRICAS_TALKING_API_KEY="your_africas_talking_api_key"

# Paystack Gateway (Payment Services)
PAYSTACK_SECRET_KEY="your_paystack_secret_key"

# Pre-Orders: deposit fraction (0.20 = 20% of total pre-order value)
PREORDER_DEPOSIT_PCT=0.20
